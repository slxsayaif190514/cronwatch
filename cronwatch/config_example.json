{
  "jobs": [
    {
      "name": "nightly-backup",
      "schedule": "0 2 * * *",
      "grace_period_seconds": 300,
      "alert_cooldown_seconds": 3600
    },
    {
      "name": "hourly-sync",
      "schedule": "0 * * * *",
      "grace_period_seconds": 120,
      "alert_cooldown_seconds": 1800
    },
    {
      "name": "every-minute-health",
      "schedule": "* * * * *",
      "grace_period_seconds": 30,
      "alert_cooldown_seconds": 300
    }
  ],
  "alerts": {
    "email": {
      "enabled": true,
      "smtp_host": "smtp.example.com",
      "smtp_port": 587,
      "from_address": "cronwatch@example.com",
      "to_addresses": ["ops@example.com"]
    },
    "webhook": {
      "enabled": false,
      "url": "https://hooks.example.com/cronwatch"
    }
  },
  "retention": {
    "max_age_days": 30
  },
  "state_file": "/var/lib/cronwatch/state.json",
  "history_file": "/var/lib/cronwatch/history.json",
  "digest_file": "/var/lib/cronwatch/digest.json",
  "check_interval_seconds": 60,
  "log_level": "INFO"
}
